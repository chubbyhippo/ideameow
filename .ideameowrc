map <leader>aP <action>(ActivateProblemsViewToolWindow)
map <leader>ar <action>(ActivateRunToolWindow)
map <leader>as <action>(ActivateStructureToolWindow)
map <leader>aS <action>(ActivateServicesToolWindow)
