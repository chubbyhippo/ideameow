<idea-plugin>
    <id>io.github.chubbyhippo.ideameow</id>
    <name>ideameow</name>
    <vendor>Chubby Hippo</vendor>
    <description><![CDATA[
        Meow-style modal editing for IntelliJ, implementing meow-edit/meow
        natively: NORMAL / INSERT / MOTION / KEYPAD states,
        selection-first commands (mark/next/back word &amp; symbol, line, block,
        find/till, visit/search), the char-thing table (, . [ ] + r s c g e w b
        p l v d .), digit expand with on-screen hints, grab / swap-grab /
        sync-grab, and a beacon approximation built on native multiple carets.
        Like meow in Emacs, the plugin binds no keys in code: the whole keymap
        (layout and SPC keypad table) lives in a bundled .ideameowrc, QWERTY
        by default, and ~/.ideameowrc overrides it entry by entry
        (.ideavimrc-style nmap / mmap / map &lt;leader&gt; / desc lines; bare
        meow command names rebind the layout itself) with a which-key popup
        for pending prefixes.
        Disable IdeaVim while using this plugin — both intercept typing.
    ]]></description>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <extensions defaultExtensionNs="com.intellij">
        <rawEditorTypedHandler implementationClass="io.github.chubbyhippo.ideameow.MeowTypedHandler"/>
        <editorActionHandler action="EditorEscape" implementationClass="io.github.chubbyhippo.ideameow.MeowEscapeHandler"/>
        <editorFactoryListener implementation="io.github.chubbyhippo.ideameow.MeowEditorFactoryListener"/>
        <postStartupActivity implementation="io.github.chubbyhippo.ideameow.TreeMeowStartup"/>
        <!-- double-ESC in a tool window (terminal, AI chat, anything that
             swallows single ESC) returns focus to the editor -->
        <postStartupActivity implementation="io.github.chubbyhippo.ideameow.ToolWindowEscapeStartup"/>
        <statusBarWidgetFactory id="MeowMode" implementation="io.github.chubbyhippo.ideameow.MeowWidgetFactory"/>
        <notificationGroup id="ideameow" displayType="BALLOON"/>
        <!-- IdeaVim-style floating "Reload" button on the ~/.ideameowrc editor:
             appears when the buffer's PARSED config differs from the loaded one
             (comment/formatting edits don't count) -->
        <editorFloatingToolbarProvider implementation="io.github.chubbyhippo.ideameow.RcReloadFloatingToolbar"/>
        <!-- shift+arrows collide with the editor's shift-selection actions;
             windmove wins the conflict, like windmove-default-keybindings -->
        <actionPromoter implementation="io.github.chubbyhippo.ideameow.WindmovePromoter"/>
    </extensions>
    <applicationListeners>
        <listener class="io.github.chubbyhippo.ideameow.MeowActionIdListener"
                  topic="com.intellij.openapi.actionSystem.ex.AnActionListener"/>
    </applicationListeners>
    <actions>
        <action id="Ideameow.ReloadRc" class="io.github.chubbyhippo.ideameow.ReloadRcAction"
                text="Reload .ideameowrc" description="Reload the ~/.ideameowrc configuration"/>
        <action id="Ideameow.EditRc" class="io.github.chubbyhippo.ideameow.EditRcAction"
                text="Edit .ideameowrc" description="Open ~/.ideameowrc in the editor"/>
        <group id="Ideameow.ReloadRcFloating.group" class="io.github.chubbyhippo.ideameow.ReloadRcFloatingActionGroup">
            <action id="Ideameow.ReloadRcFloating" class="io.github.chubbyhippo.ideameow.ReloadRcFloatingAction"
                    text="Reload .ideameowrc"
                    description="Reload ~/.ideameowrc when the editor content differs from the loaded configuration"
                    use-shortcut-of="ExternalSystem.ProjectRefreshAction"/>
        </group>
        <action id="Ideameow.TrackActionIds" class="io.github.chubbyhippo.ideameow.TrackActionIdsAction"
                text="Track Action IDs"
                description="Show the id of every performed action, for &lt;action&gt;(...) mappings in ~/.ideameowrc"/>
        <!-- Emacs (windmove-default-keybindings): Shift+arrows select the
             window in that direction — editor splits and diff panes alike.
             Also on SPC w h/j/k/l via the rc, mirroring init.el's C-c w. -->
        <action id="Ideameow.WindmoveLeft" class="io.github.chubbyhippo.ideameow.WindmoveLeftAction"
                text="Windmove Left" description="Select the editor window to the left (Emacs windmove-left)">
            <keyboard-shortcut keymap="$default" first-keystroke="shift LEFT"/>
        </action>
        <action id="Ideameow.WindmoveRight" class="io.github.chubbyhippo.ideameow.WindmoveRightAction"
                text="Windmove Right" description="Select the editor window to the right (Emacs windmove-right)">
            <keyboard-shortcut keymap="$default" first-keystroke="shift RIGHT"/>
        </action>
        <action id="Ideameow.WindmoveUp" class="io.github.chubbyhippo.ideameow.WindmoveUpAction"
                text="Windmove Up" description="Select the editor window above (Emacs windmove-up)">
            <keyboard-shortcut keymap="$default" first-keystroke="shift UP"/>
        </action>
        <action id="Ideameow.WindmoveDown" class="io.github.chubbyhippo.ideameow.WindmoveDownAction"
                text="Windmove Down" description="Select the editor window below (Emacs windmove-down)">
            <keyboard-shortcut keymap="$default" first-keystroke="shift DOWN"/>
        </action>
        <!-- windmove-swap-states: the current split's file and the focus move
             to the neighbour, its file comes back. SPC w H/J/K/L via the rc,
             like init.el's C-c w map — no default chords. -->
        <action id="Ideameow.WindmoveSwapLeft" class="io.github.chubbyhippo.ideameow.WindmoveSwapLeftAction"
                text="Windmove Swap Left"
                description="Swap the current editor window with the one to the left (Emacs windmove-swap-states-left)"/>
        <action id="Ideameow.WindmoveSwapRight" class="io.github.chubbyhippo.ideameow.WindmoveSwapRightAction"
                text="Windmove Swap Right"
                description="Swap the current editor window with the one to the right (Emacs windmove-swap-states-right)"/>
        <action id="Ideameow.WindmoveSwapUp" class="io.github.chubbyhippo.ideameow.WindmoveSwapUpAction"
                text="Windmove Swap Up"
                description="Swap the current editor window with the one above (Emacs windmove-swap-states-up)"/>
        <action id="Ideameow.WindmoveSwapDown" class="io.github.chubbyhippo.ideameow.WindmoveSwapDownAction"
                text="Windmove Swap Down"
                description="Swap the current editor window with the one below (Emacs windmove-swap-states-down)"/>
    </actions>
</idea-plugin>
